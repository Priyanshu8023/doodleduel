generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Word {
  id    Int    @id @default(autoincrement())
  word  String
  level String
}

model User {
  id        Int      @id @default(autoincrement())
  username  String
  avatorUrl String?
  xp        Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
